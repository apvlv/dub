// Configuration entries for feature flags and blacklists
// Replaces Vercel Edge Config for self-hosting

model ConfigEntry {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "domains", "emails", "keys", "betaFeatures"
  value     Json     // Stores arrays or objects depending on key type
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}
