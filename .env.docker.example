#####################################################
# Dub Docker Environment Configuration
#####################################################
# Copy this file to .env.docker and configure values
# Usage: docker compose --env-file .env.docker up -d
#####################################################

#####################################################
# Application Settings
#####################################################

# App name displayed in UI
NEXT_PUBLIC_APP_NAME=Dub

# Main domain for the application
NEXT_PUBLIC_APP_DOMAIN=localhost:8888

# Short domain for link redirects
NEXT_PUBLIC_APP_SHORT_DOMAIN=localhost:8888

# Application port (default: 8888)
APP_PORT=8888

# Application domain for Traefik routing
APP_DOMAIN=localhost

#####################################################
# Authentication (REQUIRED)
#####################################################

# Generate a random 32-character secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl

# URL where the app is accessible
NEXTAUTH_URL=http://localhost:8888

#####################################################
# MySQL Database
#####################################################

# MySQL root password
MYSQL_ROOT_PASSWORD=rootpassword

# MySQL application password
MYSQL_PASSWORD=dubpassword

# MySQL port (default: 3306)
MYSQL_PORT=3306

# PlanetScale proxy port (default: 3900)
PS_PROXY_PORT=3900

#####################################################
# Redis
#####################################################

# Use local Redis instead of Upstash REST API
# Set to 'true' for self-hosted deployments
USE_LOCAL_REDIS=true

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis URL (for application)
# Note: Set automatically in docker-compose.yml
# REDIS_URL=redis://redis:6379

#####################################################
# ClickHouse (Analytics - replaces Tinybird)
#####################################################

# Use local ClickHouse instead of Tinybird
# Set to 'true' for self-hosted deployments
USE_LOCAL_CLICKHOUSE=true

# ClickHouse connection settings
# Note: CLICKHOUSE_URL, CLICKHOUSE_HOST are set automatically in docker-compose.yml
CLICKHOUSE_PASSWORD=clickhousepassword
CLICKHOUSE_DATABASE=dub
CLICKHOUSE_USER=dub

# ClickHouse HTTP port (default: 8123)
CLICKHOUSE_HTTP_PORT=8123

# ClickHouse native port (default: 9000)
CLICKHOUSE_NATIVE_PORT=9000

#####################################################
# MinIO (S3-Compatible Object Storage)
#####################################################

# MinIO root credentials
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret

# MinIO ports
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Storage configuration for application
# STORAGE_ENDPOINT is set automatically in docker-compose.yml (internal Docker network)
# STORAGE_PUBLIC_ENDPOINT is the URL clients use (browser-accessible)
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_BASE_URL=http://localhost:9000/dub-public
STORAGE_PUBLIC_BUCKET=dub-public
STORAGE_PRIVATE_BUCKET=dub-private

#####################################################
# Email (MailHog for development)
#####################################################

# MailHog ports
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# SMTP settings (configured automatically for MailHog)
# For production, configure these:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Resend API (alternative to SMTP)
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=

#####################################################
# Traefik Reverse Proxy (Optional)
#####################################################

# Email for Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# Traefik dashboard basic auth
# Generate with: htpasswd -nb admin password | sed -e s/\\$/\\$\\$/g
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz$$abc

#####################################################
# External Services (Optional)
#####################################################

# Stripe - Payments and subscriptions
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Unsplash - Custom link previews
UNSPLASH_ACCESS_KEY=

# Anthropic - AI features
ANTHROPIC_API_KEY=

# Axiom - Logging (optional)
AXIOM_TOKEN=
AXIOM_DATASET=

#####################################################
# Feature Flags
#####################################################

# Set to 'true' if this is the official Dub instance
NEXT_PUBLIC_IS_DUB=false

# Cron job secret
CRON_SECRET=

#####################################################
# Development Settings
#####################################################

# Enable debug logging
# DEBUG=*

# Node environment (development/production)
# NODE_ENV=production

#####################################################
# Background Jobs (BullMQ - replaces QStash)
#####################################################

# Use local BullMQ queue instead of Upstash QStash
# Set to 'true' for self-hosted deployments
USE_LOCAL_QUEUE=true

# Note: BullMQ uses the same Redis connection as caching
# The worker process will automatically pick up jobs from Redis
# Start the worker with: docker compose --profile worker up -d

#####################################################
# Local Config (replaces Vercel Edge Config)
#####################################################

# Use local database/Redis config instead of Vercel Edge Config
# Set to 'true' for self-hosted deployments
USE_LOCAL_CONFIG=true

# Admin API key for managing configuration
# Generate with: openssl rand -base64 32
# This key is used to access the /api/admin/config endpoints
ADMIN_API_KEY=

# Note: Local config uses:
# - Database (ConfigEntry table) as source of truth
# - Redis for caching (5 minute TTL)
# - Admin API for CRUD operations

#####################################################
# Advanced Settings
#####################################################

# Background jobs (handled internally with BullMQ)
# No external QStash needed for self-hosted setup

# Edge Config (disabled for self-hosting, replaced by local config)
# EDGE_CONFIG=
# EDGE_CONFIG_ID=

# Vercel Domains API (disabled for self-hosting)
# Use manual DNS configuration instead
# PROJECT_ID_VERCEL=
# TEAM_ID_VERCEL=
# AUTH_BEARER_TOKEN=

# Tinybird (replaced by self-hosted ClickHouse)
# TINYBIRD_API_KEY=
# TINYBIRD_API_URL=

# Upstash Redis (replaced by self-hosted Redis)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

#####################################################
# Local Geolocation (replaces Vercel Functions)
#####################################################

# Use local GeoLite2 database instead of Vercel Functions
# Set to 'true' for self-hosted deployments
USE_LOCAL_GEO=true

# Path to GeoLite2-City.mmdb database file
# Download from: https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# The database requires a free MaxMind account
# Place the file in your data directory and mount it in Docker
GEOLITE2_PATH=/app/data/GeoLite2-City.mmdb

# Note: GeoLite2 provides IP geolocation including:
# - Country, region/state, city
# - Latitude/longitude coordinates
# - Continent information
# The database should be updated monthly for best accuracy
